# ============================================================
# Mom's Saheli — environment variables
# Copy this file to .env (in the project root, NOT backend/)
# and fill in keys. Anything left blank gracefully falls back
# to fixtures or skips the provider — the swarm always runs.
# ============================================================

# === LLM cascade (order: Gemini → Qwen → Z.ai) ===
TOKEN_ROUTER_API_KEY=

# Gemini 2.5 Flash — our PRIMARY today (free tier, no card)
# Get one in 30 sec: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Qwen Cloud — sponsor primary tomorrow (grab key at booth)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Z.ai (GLM) — final fallback in cascade
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4-plus

# === Web intel ===
# Bright Data — needs an ACTIVE ZONE; without one we transparently route to Tavily
# Get token: https://brightdata.com/cp/api_keys  →  then create a Web Unlocker zone
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_ZONE=

# Tavily — free 1000 searches/mo, current Bright-Data stand-in
# Get key: https://tavily.com  (Google sign-in, no card)
TAVILY_API_KEY=

# Actionbook — Chrome-extension browser actions (Etsy publish, etc.)
ACTIONBOOK_API_KEY=
ACTIONBOOK_WORKSPACE_ID=

# === Memory + backend ===
EVERMIND_API_KEY=
EVERMIND_NAMESPACE=moms-saheli
BUTTERBASE_API_KEY=
BUTTERBASE_PROJECT_ID=

# === Orchestration (AgentField) ===
AGENTFIELD_API_KEY=
AGENTFIELD_PROJECT=moms-saheli
AGENTFIELD_CONTROL_PLANE_URL=http://localhost:8080

# === Runtime ===
APP_BASE_URL=http://localhost:8000
# USE_FIXTURES=true is fine even with live keys present —
# it only gates the *expensive* Bright Data zone scrape.
# Tavily, Gemini, and the LLM cascade all activate purely
# on key presence, independent of this flag.
USE_FIXTURES=true
LOG_LEVEL=INFO
